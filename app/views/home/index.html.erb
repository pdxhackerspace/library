<% content_for :title, site_name %>

<div class="d-flex align-items-end justify-content-between mb-3">
  <div>
    <h1 class="h-page-title mb-0"><%= site_name %></h1>
    <div class="text-13 text-secondary mt-1">
      Browse the library catalog<% unless logged_in? %> — sign in to check out books<% end %>
    </div>
  </div>
  <div class="d-flex gap-2">
    <%= link_to 'All books', books_path, class: 'btn btn-outline-secondary btn-sm' %>
    <% unless logged_in? %>
      <%= link_to 'Sign in', login_path, class: 'btn btn-primary btn-sm' %>
    <% end %>
  </div>
</div>

<%= render 'shared/home_book_section',
           title: 'Recently added',
           books: @recent_books,
           more_path: books_path %>

<%= render 'shared/home_book_section',
           title: 'Popular',
           books: @popular_books,
           more_path: books_path %>

<%= render 'shared/home_book_section',
           title: 'Discover',
           books: @random_books,
           more_path: books_path %>

<% if @featured_subject %>
  <%= render 'shared/home_book_section',
             title: @featured_subject.name,
             subtitle: 'Random subject',
             books: @subject_books,
             link_locations: logged_in? %>
<% end %>
