<% locations = local_assigns.fetch(:locations, Location.alphabetical) %>
<% content_for :title, "#{title} · #{site_name}" %>

<h1 class="h4 mb-3"><%= title %></h1>

<%= turbo_stream_from "book_metadata_lookup_#{lookup_token}" %>

<%= form_with model: book,
              class: 'card border-secondary-subtle',
              data: {
                controller: 'book-form',
                book_form_scan_url_value: (scan_isbn ? scan_isbn_books_path : ''),
                book_form_lookup_url_value: (book.persisted? ? lookup_metadata_book_path(book) : lookup_metadata_books_path),
                book_form_lookup_token_value: lookup_token
              } do |form| %>
  <%= hidden_field_tag :lookup_token, lookup_token %>
  <div class="card-body">
    <% if book.errors.any? %>
      <div class="alert alert-danger py-2 small">
        <%= book.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <% if scan_isbn %>
      <div class="mb-3 pb-3 border-bottom border-secondary-subtle">
        <div class="text-secondary small mb-2">Scan ISBN from cover photo</div>
        <input type="file"
               accept="image/*"
               capture="environment"
               class="d-none"
               data-book-form-target="photo"
               data-action="change->book-form#scanPhoto">
        <button type="button"
                class="btn btn-outline-secondary btn-sm"
                data-action="book-form#openCamera">
          <i class="bi bi-camera"></i> Take photo
        </button>
        <div data-book-form-target="scanStatus" class="small mt-2 text-secondary"></div>
      </div>
    <% end %>

    <div class="mb-3 pb-3 border-bottom border-secondary-subtle">
      <div class="text-secondary small mb-2">Book info lookup</div>
      <% if book.persisted? %>
        <button type="button"
                class="btn btn-outline-secondary btn-sm"
                data-action="book-form#lookupMetadata">
          Fill empty fields from lookup
        </button>
      <% else %>
        <div class="text-secondary small">Enter an ISBN below to look up title, authors, and other details automatically.</div>
      <% end %>
      <div id="metadata_lookup_status" data-book-form-target="metadataStatus"></div>
    </div>

    <div class="mb-3">
      <%= form.label :title, class: 'form-label' %>
      <div id="book_title">
        <%= form.text_field :title, class: 'form-control form-control-sm', required: true %>
      </div>
    </div>

    <div class="mb-3">
      <%= form.label :subtitle, class: 'form-label' %>
      <div id="book_subtitle">
        <%= form.text_field :subtitle, class: 'form-control form-control-sm' %>
      </div>
    </div>

    <div class="mb-3">
      <label class="form-label">Authors</label>
      <div id="book_author_names" data-book-form-target="authorList">
        <%= render 'author_fields', author_names: book.author_names_list %>
      </div>
      <button type="button"
              class="btn btn-outline-secondary btn-sm"
              data-action="book-form#addAuthorField">
        Add author
      </button>
    </div>

    <div class="mb-3">
      <%= form.label :published_on, 'Publication date', class: 'form-label' %>
      <div id="book_published_on">
        <%= form.date_field :published_on, class: 'form-control form-control-sm' %>
      </div>
    </div>

    <div class="mb-3">
      <label class="form-label">ISBN codes</label>
      <div data-book-form-target="isbnList">
        <% Array(book.isbn_codes_list).each do |code| %>
          <div class="input-group input-group-sm mb-2" data-book-form-target="isbnField">
            <input type="text"
                   name="book[isbn_codes][]"
                   value="<%= code %>"
                   class="form-control form-control-sm"
                   inputmode="numeric"
                   autocomplete="off"
                   data-action="input->book-form#scheduleLookup blur->book-form#scheduleLookup">
            <button type="button"
                    class="btn btn-outline-secondary"
                    data-action="book-form#removeIsbnField"
                    aria-label="Remove ISBN">×</button>
          </div>
        <% end %>
      </div>
      <button type="button"
              class="btn btn-outline-secondary btn-sm"
              data-action="book-form#addIsbnField">
        Add ISBN
      </button>
    </div>

    <div class="mb-3">
      <%= form.label :description, class: 'form-label' %>
      <div id="book_description">
        <%= form.text_area :description, rows: 5, class: 'form-control form-control-sm' %>
      </div>
    </div>

    <div class="row">
      <div class="col-md-6 mb-3">
        <%= form.label :publisher, class: 'form-label' %>
        <div id="book_publisher">
          <%= form.text_field :publisher, class: 'form-control form-control-sm' %>
        </div>
      </div>
      <div class="col-md-3 mb-3">
        <%= form.label :page_count, 'Pages', class: 'form-label' %>
        <div id="book_page_count">
          <%= form.number_field :page_count, class: 'form-control form-control-sm', min: 1 %>
        </div>
      </div>
      <div class="col-md-3 mb-3">
        <%= form.label :language, class: 'form-label' %>
        <div id="book_language">
          <%= form.text_field :language, class: 'form-control form-control-sm', placeholder: 'en' %>
        </div>
      </div>
    </div>

    <div class="mb-3">
      <label class="form-label">Subjects</label>
      <div id="book_subjects" data-book-form-target="subjectList">
        <%= render 'subject_fields', subject_names: book.subject_names_list %>
      </div>
      <button type="button"
              class="btn btn-outline-secondary btn-sm"
              data-action="book-form#addSubjectField">
        Add subject
      </button>
    </div>

    <div id="book_cover_previews" class="mb-3">
      <%= render 'cover_previews', cover_urls: [], book: book.persisted? ? book : nil %>
    </div>

    <div class="mb-3">
      <%= form.label :location_id, 'Shelf / location', class: 'form-label' %>
      <%= form.hidden_field :location_id, data: { book_form_target: 'locationId' } %>
      <% if locations.any? %>
        <div class="d-flex flex-wrap gap-2 mb-2">
          <% locations.each do |location| %>
            <button type="button"
                    class="btn btn-outline-secondary btn-sm<%= ' active' if book.location_id == location.id %>"
                    data-book-form-target="locationButton"
                    data-location-id="<%= location.id %>"
                    data-action="book-form#setLocation">
              <%= location.name %>
            </button>
          <% end %>
        </div>
      <% end %>
      <%= text_field_tag 'book[custom_location_name]',
                         nil,
                         class: 'form-control form-control-sm',
                         placeholder: 'Or enter a new location',
                         data: {
                           book_form_target: 'customLocationInput',
                           action: 'input->book-form#clearLocationSelection'
                         } %>
    </div>
    <div class="mb-3">
      <%= form.label :copies_count, 'Copies', class: 'form-label' %>
      <%= form.number_field :copies_count, class: 'form-control form-control-sm num', min: 1, value: book.copies_count %>
    </div>

    <div class="mb-3">
      <%= form.label :ebook_url, 'Ebook URL', class: 'form-label' %>
      <%= form.url_field :ebook_url, class: 'form-control form-control-sm', placeholder: 'https://…' %>
    </div>

    <div class="mb-3">
      <%= form.label :notes, 'Staff notes', class: 'form-label' %>
      <%= form.text_area :notes, rows: 3, class: 'form-control form-control-sm' %>
      <div class="form-text">Internal notes only. Not filled from ISBN lookup.</div>
    </div>

    <div class="d-flex flex-wrap gap-2">
      <%= form.submit class: 'btn btn-primary btn-sm' %>
      <% if local_assigns.fetch(:show_add_another, false) %>
        <%= form.submit 'Create book and add another', name: 'add_another', class: 'btn btn-outline-secondary btn-sm' %>
      <% end %>
      <%= link_to 'Cancel', book.persisted? ? book : books_path, class: 'btn btn-outline-secondary btn-sm' %>
    </div>
  </div>
<% end %>

<% if book.persisted? && !book.on_loan? %>
  <div class="d-flex justify-content-end mt-2">
    <%= button_to 'Delete', book, method: :delete, class: 'btn btn-outline-danger btn-sm',
                  data: { turbo_confirm: 'Remove this book from the library?' },
                  form: { data: { turbo: false } } %>
  </div>
<% end %>
