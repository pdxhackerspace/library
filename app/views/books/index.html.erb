<% content_for :title, "Books · #{site_name}" %>

<div class="d-flex align-items-end justify-content-between mb-3">
  <div>
    <div class="text-secondary small mb-1"><%= link_to site_name, root_path, class: 'link-secondary' %></div>
    <h1 class="h-page-title mb-0">Books</h1>
    <div class="text-13 text-secondary mt-1">
      <span class="text-body"><%= @books.size %></span> titles ·
      <span class="text-body"><%= @books.sum(&:copies_count) %></span> copies ·
      <span class="text-success"><%= @books.count(&:available?) %></span> available
      <% if logged_in? && current_user.admin? %>
        · <span class="text-warning"><%= @active_loans.size %></span> on loan
      <% end %>
    </div>
  </div>
  <% if logged_in? && can_manage_books? %>
    <%= link_to 'Add book', new_book_path, class: 'btn btn-primary btn-sm' %>
  <% elsif logged_in? == false && guest_browse? %>
    <%= link_to 'Sign in to check out', login_path, class: 'btn btn-primary btn-sm' %>
  <% end %>
</div>

<div class="table-responsive">
  <table class="table table-sm table-hover table-compact align-middle">
    <thead class="text-secondary text-uppercase text-11">
      <tr>
        <th>Title</th>
        <th>Author</th>
        <th>Location</th>
        <th class="num">Copies</th>
        <th>Status</th>
        <% if logged_in? %>
          <th></th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% if @books.any? %>
        <% @books.each do |book| %>
          <tr>
            <td>
              <%= link_to book.title, book, class: 'link-light text-decoration-none' %>
              <% if book.ebook_url.present? %>
                <span class="ms-2"><%= ebook_link_for(book) %></span>
              <% end %>
            </td>
            <td class="text-secondary"><%= book.authors_label %></td>
            <td class="text-secondary">
              <% if book.location %>
                <% if logged_in? %>
                  <%= link_to book.location.name, book.location, class: 'link-secondary text-decoration-none' %>
                <% else %>
                  <%= book.location.name %>
                <% end %>
              <% else %>
                —
              <% end %>
            </td>
            <td><%= copies_count_cell(book.copies_count) %></td>
            <td><%= book_status_label(book) %></td>
            <% if logged_in? %>
              <td class="text-end">
                <% if book.available? %>
                  <%= button_to 'Check out', checkout_book_path(book), class: 'btn btn-outline-secondary btn-sm' %>
                <% else %>
                  <% loan = book.active_loan %>
                  <span class="text-secondary small">
                    <% if current_user.admin? %>
                      <%= loan.user.name %>
                      · <%= button_to 'Return', return_book_path(book), class: 'btn btn-outline-secondary btn-sm d-inline-block ms-1' %>
                    <% elsif loan.user_id == current_user.id %>
                      Checked out to you
                      · <%= button_to 'Return', return_book_path(book), class: 'btn btn-outline-secondary btn-sm d-inline-block ms-1' %>
                    <% else %>
                      On loan
                    <% end %>
                  </span>
                <% end %>
              </td>
            <% end %>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="<%= logged_in? ? 6 : 5 %>" class="text-secondary py-4 text-center">
            No books yet.<% if can_manage_books? %> <%= link_to 'Add one', new_book_path, class: 'link-light' %>.<% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
