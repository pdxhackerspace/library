<% content_for :title, "#{@book.title} · #{site_name}" %>

<div class="book-detail" data-controller="book-cover">
  <div class="text-secondary text-12 mb-3">
    <%= link_to site_name, root_path, class: 'link-secondary' %>
    · <%= link_to 'Books', books_path, class: 'link-secondary' %>
  </div>

  <div class="row g-4 align-items-start">
    <div class="col-sm-5 col-md-4 col-lg-3">
      <figure class="book-detail__cover mb-0">
        <%= book_cover_tag(@book, size: :hero, id: 'book-primary-cover', data: { book_cover_target: 'primary' }) %>
        <% if @book.covers.attachments.size > 1 %>
          <div class="book-detail__thumbs" role="list" aria-label="Other covers">
            <% @book.covers.each_with_index do |cover, index| %>
              <button type="button"
                      class="btn p-0 border-0 bg-transparent"
                      role="listitem"
                      data-action="click->book-cover#select"
                      data-book-cover-url-param="<%= url_for(cover) %>"
                      aria-label="Show cover <%= index + 1 %>">
                <%= book_cover_tag(@book, size: :thumb, attachment: cover, class: (index.zero? ? 'active' : nil), data: { book_cover_target: 'thumb' }) %>
              </button>
            <% end %>
          </div>
        <% end %>
      </figure>
    </div>

    <div class="col-sm-7 col-md-8 col-lg-9">
      <div class="d-flex flex-wrap align-items-start justify-content-between gap-3 mb-3">
        <div class="min-w-0">
          <div class="d-flex align-items-center gap-2 mb-2">
            <%= book_status_dot(@book) %>
            <span class="text-13 text-secondary"><%= @book.available? ? 'Available' : 'On loan' %></span>
          </div>
          <h1 class="h2 mb-1"><%= @book.title %></h1>
          <% if @book.subtitle.present? %>
            <div class="text-secondary text-13 mb-1"><%= @book.subtitle %></div>
          <% end %>
          <div class="text-secondary"><%= @book.authors_label %></div>
          <% if @book.metadata_imported? %>
            <div class="text-12 text-secondary mt-1">
              Catalog info from <%= book_metadata_attribution(@book) %>
            </div>
          <% end %>
        </div>

        <div class="d-flex flex-wrap gap-2 flex-shrink-0">
          <% if logged_in? %>
            <% if @book.available? %>
              <%= button_to 'Check out', checkout_book_path(@book), class: 'btn btn-primary btn-sm' %>
            <% elsif @book.active_loan&.user_id == current_user.id || current_user.admin? %>
              <%= button_to 'Return', return_book_path(@book), class: 'btn btn-primary btn-sm' %>
            <% end %>
            <% if can_manage_books? %>
              <%= link_to 'Edit', edit_book_path(@book), class: 'btn btn-outline-secondary btn-sm' %>
              <%= render 'nfc_write', book: @book %>
              <div class="dropdown">
                <button class="btn btn-outline-secondary btn-sm dropdown-toggle"
                        type="button"
                        data-bs-toggle="dropdown"
                        aria-expanded="false"
                        aria-label="More actions">
                  <i class="bi bi-three-dots"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-dark dropdown-menu-end">
                  <li>
                    <%= render 'delete_button',
                               book: @book,
                               css_class: 'dropdown-item text-danger',
                               form: { class: 'd-grid', data: { turbo: false } } %>
                  </li>
                </ul>
              </div>
            <% end %>
          <% else %>
            <%= link_to 'Sign in to check out', login_path, class: 'btn btn-primary btn-sm' %>
          <% end %>
        </div>
      </div>

      <% if @book.description.present? %>
        <div class="book-detail__description text-13 mb-4">
          <%= simple_format(@book.description) %>
        </div>
      <% end %>

      <div class="book-detail__meta">
        <% if @book.published_on.present? %>
          <div class="book-detail__meta-item">
            <div class="book-detail__meta-label">Published</div>
            <div class="book-detail__meta-value"><%= @book.published_on.strftime('%b %-d, %Y') %></div>
          </div>
        <% end %>

        <% if @book.publisher.present? %>
          <div class="book-detail__meta-item">
            <div class="book-detail__meta-label">Publisher</div>
            <div class="book-detail__meta-value"><%= @book.publisher %></div>
          </div>
        <% end %>

        <% if @book.page_count.present? %>
          <div class="book-detail__meta-item">
            <div class="book-detail__meta-label">Pages</div>
            <div class="book-detail__meta-value num"><%= @book.page_count %></div>
          </div>
        <% end %>

        <% if @book.language.present? %>
          <div class="book-detail__meta-item">
            <div class="book-detail__meta-label">Language</div>
            <div class="book-detail__meta-value"><%= @book.language %></div>
          </div>
        <% end %>

        <% if @book.location %>
          <div class="book-detail__meta-item">
            <div class="book-detail__meta-label">Location</div>
            <div class="book-detail__meta-value">
              <% if logged_in? %>
                <%= link_to @book.location.name, @book.location, class: 'link-light text-decoration-none' %>
              <% else %>
                <%= @book.location.name %>
              <% end %>
            </div>
          </div>
        <% end %>

        <% if @book.copies_count.to_i > 1 %>
          <div class="book-detail__meta-item">
            <div class="book-detail__meta-label">Copies</div>
            <div class="book-detail__meta-value num"><%= @book.copies_count %></div>
          </div>
        <% end %>

        <% if @book.subjects_label.present? %>
          <div class="book-detail__meta-item">
            <div class="book-detail__meta-label">Subjects</div>
            <div class="book-detail__meta-value"><%= @book.subjects_label %></div>
          </div>
        <% end %>

        <% if @book.ebook_url.present? %>
          <div class="book-detail__meta-item">
            <div class="book-detail__meta-label">Ebook</div>
            <div class="book-detail__meta-value"><%= ebook_link_for(@book, css: 'link-light text-13') %></div>
          </div>
        <% end %>
      </div>

      <% if @book.on_loan? %>
        <% loan = @book.active_loan %>
        <div class="book-detail__section">
          <div class="h-section-label mb-2">Loan</div>
          <div class="text-13">
            <% if logged_in? && (current_user.admin? || loan.user_id == current_user.id) %>
              <% if loan.user_id == current_user.id %>
                Checked out to you · due <%= loan.due_on.strftime('%b %-d, %Y') %>
              <% else %>
                Borrowed by <%= loan.user.name %> · due <%= loan.due_on.strftime('%b %-d, %Y') %>
              <% end %>
            <% else %>
              <span class="text-secondary">Currently on loan</span>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @book.isbn_codes.any? || (logged_in? && (@book.notes.present? || @book.metadata_imported?)) %>
        <div class="book-detail__section">
          <div class="h-section-label mb-2">System</div>
          <div class="book-detail__meta">
            <% if @book.isbn_codes.any? %>
              <div class="book-detail__meta-item">
                <div class="book-detail__meta-label">ISBN</div>
                <div class="book-detail__meta-value text-secondary"><%= @book.isbn_codes.join(', ') %></div>
              </div>
            <% end %>

            <% if logged_in? && @book.notes.present? %>
              <div class="book-detail__meta-item">
                <div class="book-detail__meta-label">Staff notes</div>
                <div class="book-detail__meta-value text-secondary"><%= simple_format(@book.notes) %></div>
              </div>
            <% end %>

            <% if logged_in? && @book.metadata_imported? %>
              <div class="book-detail__meta-item">
                <div class="book-detail__meta-label">Catalog source</div>
                <div class="book-detail__meta-value text-secondary">
                  <%= book_metadata_attribution(@book) %>
                  <% if @book.metadata_fetched_at.present? %>
                    · <%= time_ago_in_words(@book.metadata_fetched_at) %> ago
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <% if params[:write_nfc].present? && can_manage_books? %>
    <div class="mt-4 pt-3 border-top border-secondary-subtle">
      <div class="h-section-label mb-2">NFC tag</div>
      <%= render 'nfc_write', book: @book, auto_prompt: true %>
    </div>
  <% end %>
</div>
