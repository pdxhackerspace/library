<%= form_with url: login_path, class: 'card border-secondary-subtle' do |form| %>
  <div class="card-body">
    <div class="mb-3">
      <%= label_tag :email, 'Email', class: 'form-label' %>
      <%= email_field_tag :email, params[:email], class: 'form-control form-control-sm', required: true, autofocus: true %>
    </div>
    <div class="mb-3">
      <%= label_tag :password, 'Password', class: 'form-label' %>
      <%= password_field_tag :password, nil, class: 'form-control form-control-sm', required: true %>
    </div>
    <%= form.submit 'Sign in', class: 'btn btn-primary btn-sm w-100' %>
  </div>
<% end %>

<% if OidcConfig.configured? %>
  <div class="text-center text-secondary small my-3">or</div>
  <%= button_to 'Sign in with OIDC', '/auth/oidc',
                method: :post,
                data: { turbo: false },
                class: 'btn btn-outline-secondary btn-sm w-100' %>
<% end %>
