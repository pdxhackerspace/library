<% if OidcConfig.configured? %>
  <div class="card border-secondary-subtle">
    <div class="card-body">
      <%= button_to 'Sign in with SSO',
                    '/auth/oidc',
                    method: :post,
                    data: { turbo: false },
                    class: 'btn btn-primary btn-sm w-100' %>
      <p class="text-secondary text-12 mt-2 mb-0">Use your organization account.</p>
    </div>
  </div>

  <details class="mt-3">
    <summary class="text-secondary text-13">Sign in with email and password</summary>
    <div class="mt-3">
      <%= render 'local_form', autofocus: false, primary: false %>
    </div>
  </details>
<% else %>
  <%= render 'local_form', autofocus: true %>
<% end %>
