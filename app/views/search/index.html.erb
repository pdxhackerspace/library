<% search_scope = current_user.admin? ? 'books, authors, subjects, publishers, and users' : 'books, authors, subjects, and publishers' %>

<% content_for :title, (@query.present? ? "Search: #{@query}" : 'Search') + " · #{site_name}" %>

<div class="mb-3">
  <h1 class="h-page-title mb-0">Search</h1>
</div>

<%= form_with url: search_path, method: :get, class: 'mb-4' do %>
  <div class="input-group input-group-sm" style="max-width: 32rem;">
    <input type="search"
           name="q"
           value="<%= @query %>"
           class="form-control form-control-sm"
           placeholder="Search <%= search_scope %>…"
           autofocus>
    <button type="submit" class="btn btn-outline-secondary">Search</button>
  </div>
<% end %>

<% if @query.blank? %>
  <p class="text-secondary text-13 mb-0">Search across <%= search_scope %>.</p>
<% elsif !@results.any? %>
  <p class="text-secondary text-13 mb-0">No results for “<%= @query %>”.</p>
<% else %>
  <div class="text-13 text-secondary mb-3">
    <span class="text-body"><%= @results.total_count %></span> result<%= @results.total_count == 1 ? '' : 's' %> for “<%= @query %>”
  </div>

  <% if @results.books.any? %>
    <h2 class="h-section-label">Books</h2>
    <%= render 'shared/book_list', books: @results.books %>
  <% end %>

  <% if @results.authors.any? %>
    <h2 class="h-section-label">Authors</h2>
    <ul class="list-compact mb-3">
      <% @results.authors.each do |author| %>
        <li>
          <%= link_to author.name, author, class: 'link-light text-decoration-none' %>
          <span class="text-secondary"> · <%= author.books_count %> title<%= author.books_count == 1 ? '' : 's' %> · <%= author.copies_count %> cop<%= author.copies_count == 1 ? 'y' : 'ies' %></span>
        </li>
      <% end %>
    </ul>
  <% end %>

  <% if @results.subjects.any? %>
    <h2 class="h-section-label">Subjects</h2>
    <ul class="list-compact mb-3">
      <% @results.subjects.each do |subject| %>
        <li>
          <%= link_to subject.name, subject, class: 'link-light text-decoration-none' %>
          <span class="text-secondary"> · <%= subject.books_count %> title<%= subject.books_count == 1 ? '' : 's' %> · <%= subject.copies_count %> cop<%= subject.copies_count == 1 ? 'y' : 'ies' %></span>
        </li>
      <% end %>
    </ul>
  <% end %>

  <% if @results.publishers.any? %>
    <h2 class="h-section-label">Publishers</h2>
    <ul class="list-compact mb-3">
      <% @results.publishers.each do |publisher| %>
        <li>
          <%= link_to publisher.name, publisher_path(publisher.name), class: 'link-light text-decoration-none' %>
          <span class="text-secondary"> · <%= publisher.books_count %> book<%= publisher.books_count == 1 ? '' : 's' %></span>
        </li>
      <% end %>
    </ul>
  <% end %>

  <% if current_user.admin? && @results.users.any? %>
    <h2 class="h-section-label">Users</h2>
    <ul class="list-compact mb-3">
      <% @results.users.each do |user| %>
        <li>
          <%= link_to user.name, user, class: 'link-light text-decoration-none' %>
          <span class="text-secondary"> · <%= user.email %></span>
        </li>
      <% end %>
    </ul>
  <% end %>
<% end %>
