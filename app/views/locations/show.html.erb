<% content_for :title, "#{@location.name} · Locations · #{site_name}" %>

<div class="mb-3">
  <div class="text-secondary small mb-1"><%= link_to 'Locations', locations_path, class: 'link-secondary' %></div>
  <div class="dropdown d-inline-block">
    <button class="btn btn-link dropdown-toggle p-0 border-0 h-page-title text-light text-decoration-none"
            type="button"
            data-bs-toggle="dropdown"
            aria-expanded="false">
      <%= @location.name %>
    </button>
    <ul class="dropdown-menu dropdown-menu-dark">
      <li><%= link_to 'All locations', locations_path, class: 'dropdown-item' %></li>
      <li><hr class="dropdown-divider"></li>
      <% @locations.each do |location| %>
        <li>
          <%= link_to location_path(location),
                      class: "dropdown-item d-flex justify-content-between gap-3 #{'active' if location.id == @location.id}" do %>
            <span><%= location.name %></span>
            <span class="text-secondary num"><%= location.books_count.to_i %></span>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
  <div class="text-13 text-secondary mt-1">
    <span class="text-body"><%= @books.size %></span> title<%= @books.size == 1 ? '' : 's' %> ·
    <span class="text-body"><%= @copies_count %></span> copies
  </div>
</div>

<%= render 'shared/book_list', books: @books %>
