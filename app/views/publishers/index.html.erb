<% content_for :title, "Publishers · #{site_name}" %>

<div class="d-flex align-items-end justify-content-between mb-3">
  <div>
    <h1 class="h-page-title mb-0">Publishers</h1>
    <div class="text-13 text-secondary mt-1">
      <span class="text-body"><%= @publishers.size %></span> total
    </div>
  </div>
</div>

<div class="table-responsive">
  <table class="table table-sm table-hover table-compact align-middle">
    <thead class="text-secondary text-uppercase text-11">
      <tr>
        <th>Name</th>
        <th class="num">Books</th>
      </tr>
    </thead>
    <tbody>
      <% if @publishers.any? %>
        <% @publishers.each do |name, count| %>
          <tr>
            <td><%= link_to name, publisher_path(name), class: 'link-light text-decoration-none' %></td>
            <td class="num text-secondary"><%= count %></td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="2" class="text-secondary py-4 text-center">No publishers yet.</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
